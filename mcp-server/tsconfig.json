{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "Node18",
    "moduleResolution": "node16",
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": "..",
    "paths": {
      "#pikku/*": ["./packages/functions/.pikku/*"]
    }
  },
  "include": ["src/**/*"]
}
