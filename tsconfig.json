{
  "compilerOptions": {
    "strict": true,
    "jsx": "react",
    "module": "Node18",
    "moduleResolution": "node16",
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "removeComments": true,
    "noLib": false,
    "noEmit": true,
    "useUnknownInCatchVariables": false,
    "target": "ES2021",
    "sourceMap": true,
    "allowJs": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@makeanagent/server": ["./backend"],
      "@makeanagent/server/*": ["./backend/*"],
      "@makeanagent/functions": ["./packages/functions"],
      "@makeanagent/functions/*": ["./packages/functions/*"],
      "#pikku/*": ["./backend/.pikku/*"]
    }
  },
  "include": ["**/.pikku/*.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
